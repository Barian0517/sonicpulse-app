{
  "name": "sonicpulse-app",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node backend/server.cjs\" \"vite\"",
    "build": "esbuild backend/server.cjs --bundle --platform=node --outfile=src-tauri/backend-dist/backend.cjs --external:NeteaseCloudMusicApi --allow-overwrite && node -e \"require('fs').cpSync('musicfree-plugin', 'src-tauri/backend-dist/musicfree-plugin', {recursive: true}); require('fs').writeFileSync('src-tauri/backend-dist/package.json', JSON.stringify({type:'commonjs',dependencies:{NeteaseCloudMusicApi:'^4.32.0'}}))\" && npm install --prefix src-tauri/backend-dist --production && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "concurrently \"node backend/server.cjs\" \"tauri dev\""
  },
  "dependencies": {
    "@google/genai": "^1.30.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "axios": "^1.18.1",
    "big-integer": "^1.6.52",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.21",
    "express": "^5.2.1",
    "he": "^1.2.0",
    "lucide-react": "^0.555.0",
    "NeteaseCloudMusicApi": "^4.32.0",
    "opencc-js": "^1.4.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-qr-code": "^2.2.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "three": "^0.184.0",
    "webdav": "^5.10.0",
    "webm-muxer": "^5.1.4"
  },
  "pkg": {
    "scripts": [
      "node_modules/NeteaseCloudMusicApi/module/*.js",
      "node_modules/NeteaseCloudMusicApi/util/*.js"
    ],
    "assets": [
      "musicfree-plugin/**/*",
      "dist/**/*",
      "dist-jukebox/**/*"
    ]
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.1",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.14.0",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^5.0.0",
    "baseline-browser-mapping": "^2.10.40",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "pkg": "^5.8.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
